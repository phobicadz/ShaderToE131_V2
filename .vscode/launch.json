{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "ShaderToE131 Launch",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "dotnet: build",
            "program": "${workspaceFolder}/ShaderToE131/bin/Debug/net8.0/ShaderToE131.dll",
            "args": [
                "--no-preview",
                "--web-port",
                "8085",
                "--shader-dir",
                "${workspaceFolder}/Shaders",
                "--audio",
                "--loopback",
                "1",
                "--bind-address",
                "0.0.0.0"
            ],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "internalConsole"
        }
    ]
}